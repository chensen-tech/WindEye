# Copy this file to backend/.env. Never commit the real .env file.

# Neo4j (required for graph features)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# MySQL (required for authentication, RBAC, and audit logs)
MYSQL_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=user
MYSQL_POOL_SIZE=5
MYSQL_POOL_MAX=20

# Authentication: off | observe | enforce
AUTH_MODE=enforce
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# Redis (optional in off mode; recommended for enforce mode)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Audit
AUDIT_API_LOG_ENABLED=true
AUDIT_OPERATION_LOG_ENABLED=true
LOG_RETENTION_DAYS=180
LOG_SLOW_REQUEST_MS=3000

# LLM (optional; required for AI-assisted analysis)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Dify workflows (optional)
DIFY_API_KEY=
DIFY_SUBJECT_API_KEY=
DIFY_EVENT_API_KEY=
DIFY_FEATURE_API_KEY=
DIFY_REGULATION_API_KEY=
DIFY_BASE_URL=https://api.dify.ai

# Data collection and ETL
CRAWL_DEMO_MODE=true
CRAWL_SOURCE_TIMEOUT_SECONDS=15
ETL_BATCH_SIZE=100
ETL_MAX_RETRIES=3

# Knowledge graph and NLP
KG_DATASET=metaqa
NER_MODEL=rule
SPACY_MODEL=zh_core_web_sm
